// ──────────────────────────────────────────────
// RECORDS
// ──────────────────────────────────────────────
async function loadRecords() {
    document.getElementById('history-scroll').innerHTML = '<div class="h-empty">Cargando registros…</div>';
    try {
        const res = await api('getRecords', { cedula: currentEmp.cedula });
        if (res.success) {
            records = res.records || [];
            renderRecords();
            syncStatus();
        }
    } catch(e) { console.error(e); }
}

function syncStatus() {
    // Look at the last record for today
    const today  = new Date().toLocaleDateString('es-VE');
    const todayR = records.filter(r => r.fecha === today);
    const last   = todayR[todayR.length - 1];
    setStatus(last && last.tipo === 'ENTRADA');
}

function setStatus(isIn) {
    checkedIn = isIn;
    const pill = document.getElementById('status-pill');
    const lbl  = document.getElementById('status-lbl');
    const btnI = document.getElementById('btn-in');
    const btnO = document.getElementById('btn-out');
    if (isIn) {
        pill.className = 'status-pill status-in';
        lbl.textContent = 'En turno';
        btnI.style.display = 'none';
        btnO.style.display = 'flex';
    } else {
        pill.className = 'status-pill status-out';
        lbl.textContent = 'Fuera';
        btnI.style.display = 'flex';
        btnO.style.display = 'none';
    }
}

function renderRecords() {
    const el = document.getElementById('history-scroll');
    if (!records.length) {
        el.innerHTML = '<div class="h-empty">Sin registros aún.</div>'; return;
    }
    const shown = [...records].reverse().slice(0, 15);
    el.innerHTML = shown.map(r => `
        <div class="h-item">
            <div class="h-left">
                <div class="h-dot ${r.tipo === 'ENTRADA' ? 'in' : 'out'}"></div>
                <span class="h-type">${r.tipo === 'ENTRADA' ? 'Entrada' : 'Salida'}</span>
                <span class="h-time">${r.hora}</span>
            </div>
            <span class="h-date">${r.fecha}</span>
        </div>
    `).join('');
}


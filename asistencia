// CHECK IN
// ──────────────────────────────────────────────
async function doCheckIn() {
    const btn = document.getElementById('btn-in');
    btn.disabled = true; btn.classList.add('loading');
    const now   = new Date();
    const fecha = now.toLocaleDateString('es-VE');
    const hora  = now.toLocaleTimeString('es-VE', { hour12: false });
    try {
        const res = await api('register', {
            nombre: currentEmp.nombre,
            cedula: currentEmp.cedula,
            area:   currentEmp.area,
            tipo:   'ENTRADA', fecha, hora
        });
        if (res.success) {
            records.push({ tipo:'ENTRADA', fecha, hora });
            setStatus(true); renderRecords();
            toast('✅ Entrada registrada a las ' + hora, 'ok');
        } else {
            toast('❌ ' + (res.error || 'Error al registrar'), 'err');
        }
    } catch(e) { toast('❌ Error de conexión al registrar entrada.', 'err'); }
    finally { btn.disabled = false; btn.classList.remove('loading'); }
}

